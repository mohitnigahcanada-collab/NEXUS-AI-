export interface ProviderConfig {
  name: string;
  baseUrl: string;
  model: string;
  keyEnv: string;
  tier: "complex" | "reasoning" | "heavy" | "chat";
  priority: 1 | 2 | 3 | 4; // 1=primary, 4=last resort
  category: string;
  costPer1kTokens: number;
  contextLimit: number;
  benchmarks?: {
    sweBench?: number;
    mmlu?: number;
    humanEval?: number;
    latency?: number;
    testPassRate?: number;
  };
  requiresG4F?: boolean; // If true, route through g4f proxy
}

